		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "17.6.0",
		"jiti": "2.7.0",
		"oxlint": "^1.68.0",
		"svelte": "^5.43.1",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.59.4",
		"vitest": "^4.0.8"
	},
	"dependencies": {
		"gridstack": "^12.3.3",
